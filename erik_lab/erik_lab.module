<?php

/**
 * @file
 * erik_lab.module
 *
 * Sandbox for Drupal 10 re-sharpening.
 * Each section is a self-contained experiment — read, uncomment, test.
 *
 * Enable: drush en erik_lab -y
 * Rebuild: drush cr
 */

use Drupal\Core\Cache\Cache;
use Drupal\Core\Form\FormStateInterface;
use Drupal\node\NodeInterface;

// =============================================================================
// 1. HOOK_FORM_ALTER
// Alters a specific form — try it on the basic-page node form.
// =============================================================================

/**
 * Implements hook_form_alter().
 *
 * Uncomment the body below to see the alter in action.
 * Visit /node/add/page and check the title field label.
 */
function erik_lab_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  // Dump $form_id to Drupal log so you can see ALL form IDs.
  \Drupal::logger('erik_lab')->notice('form_alter fired: @id', ['@id' => $form_id]);

  // Target only the basic page node form.
  if ($form_id === 'node_page_form') {
    $form['title']['widget'][0]['value']['#title'] = t('Page title (altered by erik_lab)');
    $form['title']['widget'][0]['value']['#description'] = t('This label was changed by hook_form_alter in erik_lab.module.');
  }
}

// =============================================================================
// 2. HOOK_CRON
// Runs on every cron execution. Keep it lightweight.
// Trigger: drush cron   or   /admin/config/system/cron
// =============================================================================

/**
 * Implements hook_cron().
 *
 * Stores last-run timestamp in State API (not exported, not in config).
 * Pushes a heavy job to the queue instead of doing it inline.
 */
function erik_lab_cron(): void {
  // State API — runtime/env value, never exported.
  $last_run = \Drupal::state()->get('erik_lab.last_cron_run', 0);
  $now      = \Drupal::time()->getRequestTime();

  \Drupal::logger('erik_lab')->notice(
    'Cron ran. Last: @last. Now: @now.',
    ['@last' => date('Y-m-d H:i:s', $last_run), '@now' => date('Y-m-d H:i:s', $now)]
  );

  \Drupal::state()->set('erik_lab.last_cron_run', $now);

  // Push work to queue instead of doing it here.
  // The QueueWorker (src/Plugin/QueueWorker/LabWorker.php) processes it.
  \Drupal::queue('erik_lab_queue')->createItem([
    'message' => 'Cron queued item at ' . date('H:i:s', $now),
  // Swap for a real nid.
    'nid'     => 1,
  ]);
}

// =============================================================================
// 3. HOOK_THEME
// Registers a custom Twig template.
// Template file: templates/lab-card.html.twig
// =============================================================================

/**
 * Implements hook_theme().
 */
function erik_lab_theme(): array {
  return [
    'lab_card' => [
      'variables' => [
        'title'       => NULL,
        'body'        => NULL,
        'extra_class' => '',
      ],
      // Drupal will look for templates/lab-card.html.twig.
    ],
  ];
}

// =============================================================================
// 4. HOOK_PREPROCESS_NODE
// Injects an extra variable into every node template.
// In Twig: {{ erik_lab_note }}
// =============================================================================

/**
 * Implements hook_preprocess_node().
 */
function erik_lab_preprocess_node(array &$variables): void {
  /** @var \Drupal\node\NodeInterface $node */
  $node = $variables['node'];

  $variables['erik_lab_note'] = t(
    'Preprocessed by erik_lab — node @nid, bundle @bundle.',
    ['@nid' => $node->id(), '@bundle' => $node->bundle()]
  );
}

// =============================================================================
// 5. HOOK_NODE_INSERT / UPDATE — Cache invalidation
// Manually invalidate cache tags when content changes.
// =============================================================================

/**
 * Implements hook_node_insert().
 */
function erik_lab_node_insert(NodeInterface $node): void {
  // node_list tag covers all node listing caches.
  Cache::invalidateTags(['node_list', 'node:' . $node->id()]);
  \Drupal::logger('erik_lab')->notice('Cache tags invalidated for new node @nid.', ['@nid' => $node->id()]);
}

/**
 * Implements hook_node_update().
 */
function erik_lab_node_update(NodeInterface $node): void {
  Cache::invalidateTags(['node:' . $node->id()]);
}

// =============================================================================
// 6. CACHE TAGS ON RENDER ARRAYS
// Attach #cache metadata so Drupal knows when to invalidate the output.
//
// Three cache metadata keys work together:
//   tags     — WHAT data the output depends on. Drupal invalidates the cache
//               entry whenever any listed tag is invalidated (e.g. when a node
//               is saved, 'node:42' is invalidated automatically).
//   contexts — WHO/WHAT the output varies by (url, user.roles, languages…).
//               Drupal uses these to store separate cache variants.
//   max-age  — HOW LONG (seconds) the entry can live. 0 = uncacheable,
//               Cache::PERMANENT = never expire based on time.
//
// Trigger: view any node — the extra element appears in the render array.
// Check the render cache: ddev drush php:eval
//   "var_dump(\Drupal::cache('render')->get('…'));"
// =============================================================================

/**
 * Implements hook_node_view().
 *
 * Adds a small cacheable render element that demonstrates  #cache metadata.
 * The element depends on the node itself and varies by user role, so
 * editors and anonymous visitors receive separate cached versions.
 */
function erik_lab_node_view(array &$build, NodeInterface $node): void {
  $build['erik_lab_cache_demo'] = [
    '#type'   => 'markup',
    '#markup' => t(
      'Cache demo — this element is keyed to node @nid.',
      ['@nid' => $node->id()]
    ),
    '#cache'  => [
      // Invalidate when this specific node is updated/deleted.
      'tags'     => ['node:' . $node->id(), 'node_list'],
      // Store separate variants per user role (e.g. editor vs. anonymous).
      'contexts' => ['user.roles'],
      // Allow time-based expiry as a safety net (1 hour).  Remove the line
      // entirely (or use Cache::PERMANENT) to rely solely on tag invalidation.
      'max-age'  => 3600,
    ],
  ];
}

